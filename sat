# -------- OTP --------
@app.route('/send_otp', methods=['POST'])
def otp():
    session['data'] = request.form.to_dict()
    session['otp'] = str(random.randint(1000,9999))

    return page("OTP", f"""
    <div class="card">
    <h3>OTP: {session['otp']}</h3>
    <form method=post action="/verify">
    <input name=otp placeholder="Enter OTP">
    <button>Verify</button>
    </form>
    </div>
    """)

# -------- VERIFY --------
@app.route('/verify', methods=['POST'])
def verify():
    if request.form['otp'] != session.get('otp'):
        return page("Error", "<h3>Invalid OTP</h3>")

    d = session['data']

    name = d['name']
    email = d['email']
    mobile = d['mobile']
    address = d['address']
    vehicle = d['vehicle']

    zone = d['zone'].split(" - ")[0]
    persons = int(d['persons']) if d['persons'] else 1
    total = zones[zone] * persons

    booking_id = str(random.randint(10**11,10**12-1))

    if d['parking'] == "With Parking":
        parking = allocate_parking(vehicle, booking_id)
    else:
        parking = "No Parking"

    # QR
    os.makedirs("static", exist_ok=True)
    qr_path = f"static/{booking_id}.png"
    qrcode.make(booking_id).save(qr_path)

    # PDF
    pdf = f"{booking_id}.pdf"
    doc = SimpleDocTemplate(pdf, pagesize=A4)
    styles = getSampleStyleSheet()

    content = [
        Paragraph("<b>RCB vs SRH Ticket</b>", styles['Title']),
        Paragraph("Chatrapati Shivaji Maharaj Stadium", styles['Normal']),
        Paragraph(f"Booking ID: {booking_id}", styles['Normal']),
        Paragraph(f"Name: {name}", styles['Normal']),
        Paragraph(f"Mobile: {mobile}", styles['Normal']),
        Paragraph(f"Address: {address}", styles['Normal']),
        Paragraph(f"Zone: {zone}", styles['Normal']),
        Paragraph(f"Persons: {persons}", styles['Normal']),
        Paragraph(f"Total: ₹{total}", styles['Normal']),
        Paragraph(f"Parking: {parking}", styles['Normal']),
        Spacer(1,20),
        Image(qr_path,150,150)
    ]
    doc.build(content)

    bookings.append({"id":booking_id,"name":name,"zone":zone,"total":total})

    return page("Success", f"""
    <h2>Booking Confirmed 🎉</h2>
    <p>ID: {booking_id}</p>
    <p>{parking}</p>
    <a href="/download/{booking_id}">Download Ticket PDF</a>
    """)

# -------- DOWNLOAD --------
@app.route('/download/<bid>')
def download(bid):
    file = f"{bid}.pdf"
    if os.path.exists(file):
        return send_file(file, as_attachment=True)
    return "File not found"

