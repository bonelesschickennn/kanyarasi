import random, os, qrcode
from reportlab.platypus import SimpleDocTemplate, Paragraph, Image, Spacer
from reportlab.lib.styles import getSampleStyleSheet
from reportlab.lib.pagesizes import A4

app = Flask(__name__)
app.secret_key = "kanyarasi_final"

# -------- DATA --------
zones = {
    "North Stand": 1500,
    "South A": 1200,
    "South B": 1200,
    "East Ground": 3000,
    "West Ground": 3000,
    "East First": 2000,
    "West First": 2000
}

parking_data = {"A":[0]*5, "B":[0]*5}
bookings = []
parking_records = []

# -------- PARKING --------
def allocate_parking(vehicle, booking_id):
    for b in ["A","B"]:
        for f in range(5):
            if parking_data[b][f] < 100:
                parking_data[b][f] += 1

                record = {
                    "vehicle": vehicle,
                    "building": b,
                    "floor": f,
                    "slot": parking_data[b][f],
                    "count": parking_data[b][f],
                    "booking_id": booking_id
                }
                parking_records.append(record)

                return f"Building {b} | Floor {f} | Slot {parking_data[b][f]} | Floor Count: {parking_data[b][f]}"
    return "Parking Full"

